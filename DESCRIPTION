Type: Package
Package: actiread
Title: Baseline Package for Reading Actigraphy and Activity Data
Version: 0.3.0
Authors@R: c(
    person(given = "John",
           family = "Muschelli",
           role = c("aut", "cre"),
           email = "muschellij2@gmail.com",
           comment = c(ORCID = "0000-0001-6469-1750"))
